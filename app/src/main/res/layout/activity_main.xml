<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.vidit.vcam.CustomOverlayView
        android:id="@+id/poseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="2dp"/>

    <View
        android:id="@+id/gridOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@android:color/transparent"/>

    <View
        android:id="@+id/focusRing"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@android:color/transparent"
        android:visibility="invisible"
        android:elevation="3dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#FFFFFF" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="#40000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">
            <View
                android:id="@+id/aiDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#D4AF37"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvScene"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI DETECTING..."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/zoomIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/zoomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#33000000"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/modesScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">
        <TextView android:id="@+id/z06x" android:layout_width="40dp" android:layout_height="40dp" android:text=".6" android:gravity="center" android:textColor="#FFFFFF"/>
        <TextView android:id="@+id/z1x" android:layout_width="40dp" android:layout_height="40dp" android:text="1" android:gravity="center" android:textColor="#FFFFFF" android:background="#4DFFFFFF"/>
        <TextView android:id="@+id/z2x" android:layout_width="40dp" android:layout_height="40dp" android:text="2" android:gravity="center" android:textColor="#FFFFFF"/>
        <TextView android:id="@+id/z5x" android:layout_width="40dp" android:layout_height="40dp" android:text="5" android:gravity="center" android:textColor="#FFFFFF"/>
        <TextView android:id="@+id/z10x" android:layout_width="40dp" android:layout_height="40dp" android:text="10" android:gravity="center" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/modesScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="30dp">
            <TextView android:id="@+id/mSlowmo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SLOWMO" android:textColor="#88FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/mVideo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIDEO" android:textColor="#88FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/mPhoto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PHOTO" android:textColor="#FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/mPortrait" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PORTRAIT" android:textColor="#88FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/mNight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NIGHT" android:textColor="#88FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/mPro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRO" android:textColor="#88FFFFFF" android:padding="12dp" android:letterSpacing="0.1"/>
        </LinearLayout>
    </HorizontalScrollView>

    <RelativeLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:paddingHorizontal="40dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="#22FFFFFF"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="#FFFFFF" />

        <View
            android:id="@+id/shutterBtn"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_centerInParent="true"
            android:background="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnFlip"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="#22FFFFFF"
            android:src="@android:drawable/ic_popup_sync"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/recPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#80000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="center"
        android:visibility="gone"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@+id/btnSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="#FF0000" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tvRecTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settingsSheet"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:background="#E6121212"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnCloseSheet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLOSE"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_margin="10dp"/>

        <Switch
            android:id="@+id/swAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Director AI (Ghost Pose)"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            android:checked="true"
            app:layout_constraintTop_toBottomOf="@+id/btnCloseSheet"/>

        <Switch
            android:id="@+id/swGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Grid Lines"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@+id/swAI"/>

        <TextView android:id="@+id/tvUpscale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Upscale Info" android:textColor="#88FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" android:padding="20dp"/>

        <TextView android:id="@+id/fps30" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/fps60" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/fps120" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/encH264" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/encHEVC" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/rowAmoled" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/rowWhite" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/checkAmoled" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/checkWhite" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
            
